  m_Script: {fileID: 11500000, guid: 0df2ddcceb2389b4d864a64d8b7d2cf4, type: 3}
  m_Name: SO_Dialogue_LivingRoomCarryBoxToStore
  m_EditorClassIdentifier: 
  background: {fileID: -4987337320017983735, guid: ef76815bb5462ca40918f9ee00dd2b1b, type: 3}
  lines:
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "V\u0169 mang th\u00F9ng \u0111\u1ED3 c\u0169 xu\u1ED1ng ph\u00F2ng kho..."
    englishText: Vu is carrying the old box down to the storage room...
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "C\u00F3 ph\u1EA3i c\u1EADu \u1EA5y \u0111ang c\u1EA5t nh\u1EEFng th\u1EE9 c\u1EE7a m\u00ECnh \u0111i kh\u00F4ng?"
    englishText: Is he putting my things away?
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "Kh\u00F4ng \u0111\u01B0\u1EE3c, m\u00ECnh ph\u1EA3i \u0111i theo. Bi\u1EBFt \u0111\u00E2u m\u00ECnh c\u00F2n gi\u00FAp \u0111\u01B0\u1EE3c c\u1EADu \u1EA5y."
    englishText: No, I have to follow him. Maybe I can still help him.
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
