  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0df2ddcceb2389b4d864a64d8b7d2cf4, type: 3}
  m_Name: SO_Dialogue_WakeUp
  m_EditorClassIdentifier: 
  background: {fileID: -4987337320017983735, guid: ef76815bb5462ca40918f9ee00dd2b1b, type: 3}
  lines:
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "Meow... s\u00E1ng r\u1ED3i \u00E0?"
    englishText: Meow... is it morning already?
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "Sao ch\u00E2n m\u00ECnh kh\u00F4ng ch\u1EA1m \u0111\u1EA5t v\u1EADy... ch\u1EAFc m\u00ECnh v\u1EABn \u0111ang m\u01A1 th\u00F4i."
    englishText: My paws are not touching the floor... I must still be dreaming.
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "G\u1ECDi V\u0169 d\u1EADy \u0111\u00E3. Anh \u1EA5y nh\u00ECn th\u1EA5y m\u00ECnh l\u00E0 m\u1ECDi th\u1EE9 s\u1EBD b\u00ECnh th\u01B0\u1EDDng."
    englishText: I should wake Vu up. Once he sees me, everything will be normal.
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
