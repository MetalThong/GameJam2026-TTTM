--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0df2ddcceb2389b4d864a64d8b7d2cf4, type: 3}
  m_Name: SO_Dialogue_WashingDishBrokenReaction
  m_EditorClassIdentifier: 
  background: {fileID: 0}
  lines:
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "Oh meow..."
    englishText: "Oh meow..."
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "\u0110\u0129a c\u1EE7a m\u00ECnh v\u00E0 V\u0169... v\u1EE1 r\u1ED3i."
    englishText: "Mine and Vu's dish... it broke."
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "\u0110\u00F3 l\u00E0 chi\u1EBFc \u0111\u0129a ng\u00E0y \u0111\u1EA7u c\u1EADu \u1EA5y cho m\u00ECnh \u0103n."
    englishText: "That was the dish he fed me from on our first day together."
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "Gi\u1EDD \u0111\u1EBFn n\u00F3 c\u0169ng bi\u1EBFn m\u1EA5t, V\u0169 s\u1EBD l\u1EA5y g\u00EC \u0111\u1EC3 nh\u1EDB m\u00ECnh?"
    englishText: "Now even it is gone. What will Vu use to remember me?"
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "M\u00ECnh ph\u1EA3i t\u00ECm l\u1EA1i th\u1EE9 g\u00EC \u0111\u00F3. M\u00ECnh kh\u00F4ng mu\u1ED1n b\u1ECB c\u1EADu \u1EA5y qu\u00EAn."
    englishText: "I have to find something else. I do not want him to forget me."
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
