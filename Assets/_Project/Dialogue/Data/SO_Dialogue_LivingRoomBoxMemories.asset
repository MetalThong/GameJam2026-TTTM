MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0df2ddcceb2389b4d864a64d8b7d2cf4, type: 3}
  m_Name: SO_Dialogue_LivingRoomBoxMemories
  m_EditorClassIdentifier: 
  background: {fileID: -4987337320017983735, guid: ef76815bb5462ca40918f9ee00dd2b1b, type: 3}
  lines:
  - speakerName: "Vũ"
    englishSpeakerName: Vu
    text: "Hmm, sao hộp lại rơi nhỉ?"
    englishText: "Hmm, why did the box fall?"
    portrait: {fileID: -4254258901546231152, guid: c5d997eca51e38d418373f1e8fdc90ce, type: 3}
  - speakerName: "Vũ"
    englishSpeakerName: Vu
    text: "Toàn mấy món đồ cũ của Silly..."
    englishText: "It's all Silly's old things..."
    portrait: {fileID: -4254258901546231152, guid: c5d997eca51e38d418373f1e8fdc90ce, type: 3}
  - speakerName: "Vũ"
    englishSpeakerName: Vu
    text: "Cái chuông nhỏ này hồi đó nó cứ tha đi khắp nhà."
    englishText: "This little bell... it used to carry it all over the house."
    portrait: {fileID: -4254258901546231152, guid: c5d997eca51e38d418373f1e8fdc90ce, type: 3}
  - speakerName: "Vũ"
    englishSpeakerName: Vu
    text: "Còn cuộn len này nữa, chắc nó vẫn nhớ."
    englishText: "And this ball of yarn too. It probably still remembers."
    portrait: {fileID: -4254258901546231152, guid: c5d997eca51e38d418373f1e8fdc90ce, type: 3}
  - speakerName: "Vũ"
    englishSpeakerName: Vu
    text: "Có lẽ mình nên mang đi. Trước hết cần tìm cái bát của Silly nữa."
    englishText: "Maybe I should take it away. First, I also need to find Silly's bowl."
    portrait: {fileID: -4254258901546231152, guid: c5d997eca51e38d418373f1e8fdc90ce, type: 3}
