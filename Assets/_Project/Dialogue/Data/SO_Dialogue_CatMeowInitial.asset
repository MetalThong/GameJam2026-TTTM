  background: {fileID: 0}
  lines:
  - speakerName: Silly
    text: "Meo... anh Vũ ơi, dậy đi!"
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    text: "Ngủ say quá. Chắc mình phải gọi lớn hơn một chút."
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    text: "Ấn E liên tục để gọi anh ấy dậy."
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
