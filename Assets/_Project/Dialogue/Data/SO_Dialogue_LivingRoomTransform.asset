  background: {fileID: 0}
  lines:
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "Ơ... sao tự nhiên mình lại biến thành dạng này?"
    englishText: "Huh... why did I suddenly turn into this form?"
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "Phải chọc giận ông chủ mới được."
    englishText: "I need to make the owner angry."
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "DÁM KHÔNG VUỐT VE CẢM ƠN TA."
    englishText: "How dare he refuse to pet me and thank me."
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
