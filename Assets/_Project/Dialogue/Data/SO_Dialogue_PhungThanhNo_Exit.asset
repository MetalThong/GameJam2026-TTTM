  lines:
  - speakerName: "V\u0169"
    englishSpeakerName: Vu
    text: "M\u1EC7t th\u1EADt..."
    englishText: I'm exhausted...
    portrait: {fileID: -4254258901546231152, guid: c5d997eca51e38d418373f1e8fdc90ce, type: 3}
  - speakerName: "V\u0169"
    englishSpeakerName: Vu
    text: "M\u00ECnh ph\u1EA3i xu\u1ED1ng t\u1EA7ng c\u00E1i \u0111\u00E3."
    englishText: I need to go downstairs first.
