  m_Script: {fileID: 11500000, guid: 0df2ddcceb2389b4d864a64d8b7d2cf4, type: 3}
  m_Name: SO_Dialogue_LivingRoomFindBowl
  m_EditorClassIdentifier: 
  background: {fileID: -4987337320017983735, guid: ef76815bb5462ca40918f9ee00dd2b1b, type: 3}
  lines:
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "V\u0169 \u0111ang t\u00ECm b\u00E1t \u0103n c\u1EE7a m\u00ECnh... c\u1EADu \u1EA5y v\u1EABn nh\u1EDB Silly \u0111\u00FAng kh\u00F4ng?"
    englishText: Vu is looking for my food bowl... he still remembers Silly, right?
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "N\u1EBFu m\u00ECnh t\u00ECm \u0111\u01B0\u1EE3c c\u00E1i b\u00E1t, ch\u1EAFc c\u1EADu \u1EA5y s\u1EBD bi\u1EBFt m\u00ECnh v\u1EABn \u1EDF \u0111\u00E2y."
    englishText: If I find the bowl, maybe he will know I am still here.
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
  - speakerName: Silly
    englishSpeakerName: Silly
    text: "M\u00ECnh s\u1EBD gi\u00FAp c\u1EADu \u1EA5y. Ch\u1EC9 c\u1EA7n c\u1EADu \u1EA5y nh\u00ECn v\u1EC1 ph\u00EDa m\u00ECnh m\u1ED9t ch\u00FAt th\u00F4i."
    englishText: I will help him. I only need him to look my way, just a little.
    portrait: {fileID: 6468568510307345621, guid: 0c05e137063d43e429af4b01ffae35ac, type: 3}
