  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Silly \xE0,\r\nN\u1EBFu c\xF3 ai h\u1ECFi em \u0111\xE3 s\u1ED1ng bao
    l\xE2u, anh s\u1EBD ch\u1EB3ng nh\u1EDB n\u1ED5i con s\u1ED1. Nh\u01B0ng n\u1EBFu
    h\u1ECD h\u1ECFi em \u0111\xE3 \u0111\u01B0\u1EE3c y\xEAu th\u01B0\u01A1ng \u0111\u1EBFn
    nh\u01B0\u1EDDng n\xE0o, anh c\xF3 th\u1EC3 k\u1EC3 m\xE3i kh\xF4ng h\u1EBFt.\r\nC\u1EA3m
    \u01A1n em v\xEC \u0111\xE3 l\u1EDBn l\xEAn c\xF9ng anh, v\xEC \u0111\xE3 \u0111\u1EC3
    l\u1EA1i d\u1EA5u ch\xE2n tr\xEAn t\u1EEBng trang nh\u1EADt k\xFD n\xE0y. C\xF3
    th\u1EC3 m\u1ED9t ng\xE0y n\xE0o \u0111\xF3 anh s\u1EBD gi\xE0 \u0111i, nh\u01B0ng
    anh s\u1EBD kh\xF4ng \u0111\u1EC3 c\xE1i t\xEAn Silly bi\u1EBFn m\u1EA5t. "
